<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login — Vignan CMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-body">
<div class="auth-container">
    <div class="auth-left admin-auth-left">
        <div class="auth-brand"><i class="fas fa-shield-alt"></i> Admin Portal</div>
        <span class="admin-badge"><i class="fas fa-lock"></i> Restricted Access</span>
        <h1>Administration Control Center</h1>
        <p>Authorized administrators only. All access is logged and monitored for security purposes.</p>
        <div class="auth-features">
            <div class="auth-feature"><i class="fas fa-check-circle"></i> Manage all student complaints</div>
            <div class="auth-feature"><i class="fas fa-check-circle"></i> Update complaint status</div>
            <div class="auth-feature"><i class="fas fa-check-circle"></i> View analytics & reports</div>
            <div class="auth-feature"><i class="fas fa-check-circle"></i> Full system oversight</div>
        </div>
        <div style="margin-top:1.5rem;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);border-radius:12px;padding:0.875rem 1rem;position:relative;z-index:1">
            <p style="font-size:0.78rem;color:#FCA5A5;margin:0;display:flex;align-items:center;gap:0.5rem"><i class="fas fa-exclamation-triangle"></i> Unauthorized access is strictly prohibited and will be reported.</p>
        </div>
        <i class="fas fa-shield-alt auth-illustration admin-illustration"></i>
    </div>
    <div class="auth-right">
        <div class="auth-form-container">
            <div class="auth-header">
                <h2>Admin Sign In</h2>
                <p>Enter your administrator credentials</p>
            </div>
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>
            <form action="/admin/login" method="POST" id="adminForm">
                <div class="form-group">
                    <label for="email">Admin Email</label>
                    <div class="input-group">
                        <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(--text-muted)"><i class="fas fa-envelope"></i></span>
                        <input type="email" id="email" name="email" class="form-control" style="padding-left:2.5rem" required placeholder="admin@vignan.ac.in" />
                    </div>
                </div>
                <div class="form-group">
                    <label for="password">Admin Password</label>
                    <div class="input-group">
                        <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(--text-muted)"><i class="fas fa-key"></i></span>
                        <input type="password" id="password" name="password" class="form-control" style="padding-left:2.5rem" required placeholder="Admin password" />
                        <button type="button" class="toggle-password" onclick="togglePwd('password','eye1')"><i class="fas fa-eye" id="eye1"></i></button>
                    </div>
                </div>
                <button type="submit" class="btn btn-admin btn-full btn-lg" id="submitBtn"><i class="fas fa-shield-alt"></i> Access Admin Panel</button>
            </form>
            <div class="auth-divider">Student?</div>
            <a href="/login" class="btn btn-outline btn-full" style="font-size:0.82rem"><i class="fas fa-user"></i> Student Login Portal</a>
        </div>
    </div>
</div>
<script>
function togglePwd(id,iconId){const f=document.getElementById(id),i=document.getElementById(iconId);f.type=f.type==='password'?(i.classList.replace('fa-eye','fa-eye-slash'),'text'):(i.classList.replace('fa-eye-slash','fa-eye'),'password');}
document.getElementById('adminForm').onsubmit=function(){const b=document.getElementById('submitBtn');b.innerHTML='<i class="fas fa-spinner fa-spin"></i> Authenticating...';b.disabled=true;};
</script>
</body>
</html>
