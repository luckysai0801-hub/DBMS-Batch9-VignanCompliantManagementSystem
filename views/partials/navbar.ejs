<!-- views/partials/navbar.ejs -->
<nav class="navbar" id="mainNav">
    <div class="nav-container">
        <a href="/" class="nav-brand">
            <i class="fas fa-graduation-cap"></i>
            <span>Vignan <strong>CMS</strong></span>
        </a>
        <div class="nav-links" id="navLinks">
            <a href="/" class="nav-link">Home</a>
            <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.role === 'admin') { %>
                <a href="/admin/dashboard" class="nav-link">Dashboard</a>
                <% } else { %>
                <a href="/dashboard" class="nav-link">Dashboard</a>
                <a href="/complaints/new" class="nav-link">New Complaint</a>
                <% } %>
                <a href="/logout" class="btn btn-outline" style="padding:0.4rem 1rem;font-size:0.85rem"><i class="fas fa-sign-out-alt"></i> Logout</a>
            <% } else { %>
                <a href="/login" class="nav-link">Login</a>
                <a href="/register" class="btn btn-primary" style="padding:0.4rem 1rem;font-size:0.85rem"><i class="fas fa-user-plus"></i> Register</a>
            <% } %>
        </div>
        <button class="nav-toggle" id="navToggle"><i class="fas fa-bars"></i></button>
    </div>
</nav>
