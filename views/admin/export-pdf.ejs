<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complaints Report — VEC CMS</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #fff; color: #1a1a2e; font-size: 12px; }

        .pdf-header {
            background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%);
            color: #fff;
            padding: 28px 36px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        .pdf-header .logo-area h1 { font-size: 20px; font-weight: 700; letter-spacing: 0.5px; }
        .pdf-header .logo-area p { font-size: 11px; opacity: 0.8; margin-top: 4px; }
        .pdf-header .report-meta { text-align: right; font-size: 11px; opacity: 0.85; }
        .pdf-header .report-meta strong { font-size: 14px; display: block; margin-bottom: 4px; }

        .stats-row {
            display: flex;
            gap: 12px;
            padding: 0 36px;
            margin-bottom: 24px;
        }
        .stat-box {
            flex: 1;
            border-radius: 8px;
            padding: 14px 12px;
            text-align: center;
            border-left: 4px solid;
        }
        .stat-box h3 { font-size: 26px; font-weight: 800; }
        .stat-box p { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; font-weight: 600; }
        .stat-total    { background: #e0e7ff; border-color: #4338ca; color: #3730a3; }
        .stat-pending  { background: #fef3c7; border-color: #d97706; color: #92400e; }
        .stat-progress { background: #dbeafe; border-color: #2563eb; color: #1e40af; }
        .stat-resolved { background: #d1fae5; border-color: #059669; color: #065f46; }
        .stat-rejected { background: #fee2e2; border-color: #dc2626; color: #991b1b; }

        .section-title {
            padding: 0 36px 10px;
            font-size: 14px;
            font-weight: 700;
            color: #1e1b4b;
            border-bottom: 2px solid #e0e7ff;
            margin-bottom: 12px;
        }

        table {
            width: calc(100% - 72px);
            margin: 0 36px;
            border-collapse: collapse;
            font-size: 11px;
        }
        thead tr { background: #1e1b4b; color: #fff; }
        thead th { padding: 9px 10px; text-align: left; font-weight: 600; font-size: 10px; text-transform: uppercase; letter-spacing: 0.4px; }
        tbody tr:nth-child(even) { background: #f5f3ff; }
        tbody tr:hover { background: #e0e7ff; }
        tbody td { padding: 8px 10px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; }
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 9.5px;
            font-weight: 700;
            text-transform: uppercase;
        }
        .s-pending   { background:#fef3c7; color:#92400e; }
        .s-in-progress { background:#dbeafe; color:#1e40af; }
        .s-resolved  { background:#d1fae5; color:#065f46; }
        .s-rejected  { background:#fee2e2; color:#991b1b; }
        .p-high   { background:#fee2e2; color:#991b1b; }
        .p-medium { background:#fef3c7; color:#92400e; }
        .p-low    { background:#d1fae5; color:#065f46; }

        .pdf-footer {
            margin: 28px 36px 0;
            padding: 12px 0;
            border-top: 2px solid #e0e7ff;
            font-size: 10px;
            color: #6b7280;
            display: flex;
            justify-content: space-between;
        }

        .no-print-bar {
            position: fixed;
            top: 0; left: 0; right: 0;
            background: #1e1b4b;
            color: #fff;
            padding: 10px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 9999;
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 13px;
        }
        .no-print-bar button {
            background: #4f46e5;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .no-print-bar button:hover { background: #6366f1; }
        .no-print-bar a {
            color: #a5b4fc;
            font-size: 12px;
            text-decoration: none;
            margin-left: auto;
        }
        .body-offset { padding-top: 46px; }

        @media print {
            .no-print-bar { display: none !important; }
            .body-offset { padding-top: 0 !important; }
            table { page-break-inside: auto; }
            tr { page-break-inside: avoid; }
        }
    </style>
</head>
<body>

<!-- Print Control Bar (hidden on print) -->
<div class="no-print-bar">
    <span>📄 <strong>Complaints Report</strong> — Ready for PDF export</span>
    <button onclick="window.print()">🖨️ Save as PDF / Print</button>
    <a href="/admin/reports">← Back to Reports</a>
</div>

<div class="body-offset">
    <!-- Header -->
    <div class="pdf-header">
        <div class="logo-area">
            <h1>🎓 Vignan Engineering College</h1>
            <p>Complaint Management System — Official Report</p>
        </div>
        <div class="report-meta">
            <strong>Complaints Summary Report</strong>
            Generated: <%= generatedAt %><br>
            Total Records: <strong><%= complaints.length %></strong>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
        <div class="stat-box stat-total">
            <h3><%= stats.total || 0 %></h3><p>Total</p>
        </div>
        <div class="stat-box stat-pending">
            <h3><%= stats.pending || 0 %></h3><p>Pending</p>
        </div>
        <div class="stat-box stat-progress">
            <h3><%= stats.in_progress || 0 %></h3><p>In Progress</p>
        </div>
        <div class="stat-box stat-resolved">
            <h3><%= stats.resolved || 0 %></h3><p>Resolved</p>
        </div>
        <div class="stat-box stat-rejected">
            <h3><%= stats.rejected || 0 %></h3><p>Rejected</p>
        </div>
    </div>

    <!-- Table -->
    <div class="section-title">📋 All Complaints — Detailed List</div>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Complaint ID</th>
                <th>Student Name</th>
                <th>Title</th>
                <th>Category</th>
                <th>Department</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Submitted</th>
            </tr>
        </thead>
        <tbody>
            <% complaints.forEach((c, i) => { %>
            <tr>
                <td style="color:#9ca3af; font-size:10px"><%= i+1 %></td>
                <td style="font-weight:700; color:#4338ca"><%= c.complaint_id %></td>
                <td><%= c.student_name %></td>
                <td style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap"><%= c.title %></td>
                <td><%= c.category %></td>
                <td><%= c.department %></td>
                <td>
                    <span class="badge p-<%= c.priority.toLowerCase() %>"><%= c.priority %></span>
                </td>
                <td>
                    <span class="badge s-<%= c.status.toLowerCase().replace(' ','-') %>"><%= c.status %></span>
                </td>
                <td><%= c.submitted_date %></td>
            </tr>
            <% }) %>
        </tbody>
    </table>

    <!-- Footer -->
    <div class="pdf-footer">
        <span>Vignan Engineering College — Complaint Management System</span>
        <span>Report generated on <%= generatedAt %> • CONFIDENTIAL</span>
    </div>
</div>

<script>
    // Auto-trigger print dialog after page loads
    window.onload = function() {
        setTimeout(() => window.print(), 800);
    };
</script>
</body>
</html>
