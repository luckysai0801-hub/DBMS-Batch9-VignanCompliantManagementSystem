<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard — CMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/admin.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="dashboard-body">
<%- include('../partials/admin-sidebar', { activePage: 'dashboard' }) %>
<div class="main-content" id="mainContent">
    <div class="topbar">
        <div class="topbar-left">
            <div class="breadcrumb"><span>Admin</span><i class="fas fa-chevron-right"></i><span>Dashboard</span></div>
            <h1><i class="fas fa-tachometer-alt"></i> Admin Dashboard</h1>
            <p>Welcome, <strong><%= user.full_name %></strong> — System Overview</p>
        </div>
        <a href="/admin/complaints" class="btn btn-primary"><i class="fas fa-folder-open"></i> Manage Complaints</a>
    </div>

    <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success fade-in"><i class="fas fa-check-circle"></i> <%= success %><button class="alert-close" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button></div><% } %>

    <div class="stats-grid stats-grid-6">
        <div class="stat-card stat-total"><div class="stat-icon"><i class="fas fa-folder-open"></i></div><div class="stat-info"><h3><%= stats.total || 0 %></h3><p>Total</p></div></div>
        <div class="stat-card stat-pending"><div class="stat-icon"><i class="fas fa-clock"></i></div><div class="stat-info"><h3><%= stats.pending || 0 %></h3><p>Pending</p></div></div>
        <div class="stat-card stat-progress"><div class="stat-icon"><i class="fas fa-spinner"></i></div><div class="stat-info"><h3><%= stats.in_progress || 0 %></h3><p>In Progress</p></div></div>
        <div class="stat-card stat-resolved"><div class="stat-icon"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h3><%= stats.resolved || 0 %></h3><p>Resolved</p></div></div>
        <div class="stat-card stat-rejected"><div class="stat-icon"><i class="fas fa-times-circle"></i></div><div class="stat-info"><h3><%= stats.rejected || 0 %></h3><p>Rejected</p></div></div>
        <div class="stat-card stat-users"><div class="stat-icon"><i class="fas fa-users"></i></div><div class="stat-info"><h3><%= stats.users || 0 %></h3><p>Students</p></div></div>
    </div>

    <div class="dashboard-grid-2">
        <div class="card">
            <div class="card-header"><h3><i class="fas fa-list-alt"></i> Recent Complaints</h3><a href="/admin/complaints" class="btn btn-sm btn-outline">View All <i class="fas fa-arrow-right"></i></a></div>
            <div class="card-body" style="padding:0">
                <% if (!recentComplaints || recentComplaints.length === 0) { %>
                <div class="empty-state"><i class="fas fa-inbox"></i><h4>No complaints yet</h4></div>
                <% } else { %>
                <div class="table-responsive">
                    <table class="data-table">
                        <thead><tr><th>ID</th><th>Title</th><th>Student</th><th>Priority</th><th>Status</th><th>Action</th></tr></thead>
                        <tbody>
                            <% recentComplaints.forEach(c => { %>
                            <tr>
                                <td><span class="complaint-id"><%= c.complaint_id %></span></td>
                                <td class="complaint-title"><%= c.title %></td>
                                <td style="font-size:0.82rem;color:var(--text-secondary)"><%= c.user_name %></td>
                                <td><span class="priority-badge priority-<%= c.priority.toLowerCase() %>"><%= c.priority %></span></td>
                                <td><span class="status-badge status-<%= c.status.toLowerCase().replace(' ','-') %>"><%= c.status %></span></td>
                                <td><a href="/admin/complaints/<%= c.id %>" class="btn btn-xs btn-view"><i class="fas fa-eye"></i></a></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } %>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><h3><i class="fas fa-chart-pie"></i> By Category</h3></div>
            <div class="card-body">
                <% if (!byCategory || byCategory.length === 0) { %>
                <div class="empty-state" style="padding:2rem"><i class="fas fa-chart-bar"></i><h4>No data yet</h4></div>
                <% } else { %>
                <div style="position: relative; height: 300px; width: 100%;">
                    <canvas id="categoryChart"></canvas>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top: 1.5rem">
        <div class="card-header"><h3><i class="fas fa-building"></i> By Department</h3></div>
        <div class="card-body">
            <% if (byDepartment && byDepartment.length > 0) { %>
            <div style="position: relative; height: 350px; width: 100%;">
                <canvas id="deptChart"></canvas>
            </div>
            <% } else { %>
            <div class="empty-state" style="padding:2rem"><i class="fas fa-chart-bar"></i><h4>No data yet</h4></div>
            <% } %>
        </div>
    </div>
</div>
<script src="/js/admin.js"></script>
<script>
    // -------------------------------------------------------------
    // Chart.js Implementations - For an impressive interactive UI
    // -------------------------------------------------------------
    const categoryData = <%- JSON.stringify(byCategory || []) %>;
    if (categoryData.length > 0 && document.getElementById('categoryChart')) {
        const catLabels = categoryData.map(d => d.category);
        const catCounts = categoryData.map(d => d.count);
        
        new Chart(document.getElementById('categoryChart'), {
            type: 'doughnut',
            data: {
                labels: catLabels,
                datasets: [{
                    data: catCounts,
                    backgroundColor: ['#4F46E5', '#10B981', '#F59E0B', '#EF4444', '#8B5CF6', '#3B82F6', '#EC4899', '#14B8A6', '#F43F5E', '#10B981'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    legend: { position: 'right', labels: { boxWidth: 12, usePointStyle: true, padding: 20 } },
                    tooltip: { backgroundColor: 'rgba(15, 23, 42, 0.9)', padding: 12, cornerRadius: 8 }
                }
            }
        });
    }

    const deptData = <%- JSON.stringify(byDepartment || []) %>;
    if (deptData.length > 0 && document.getElementById('deptChart')) {
        const deptLabels = deptData.map(d => d.department);
        const deptCounts = deptData.map(d => d.count);
        
        new Chart(document.getElementById('deptChart'), {
            type: 'bar',
            data: {
                labels: deptLabels,
                datasets: [{
                    label: 'Complaints',
                    data: deptCounts,
                    backgroundColor: '#3B82F6',
                    borderRadius: 6,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false }, ticks: { precision: 0 } },
                    x: { grid: { display: false, drawBorder: false } }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: { backgroundColor: 'rgba(15, 23, 42, 0.9)', padding: 12, cornerRadius: 8 }
                }
            }
        });
    }
</script>
</body>
</html>
