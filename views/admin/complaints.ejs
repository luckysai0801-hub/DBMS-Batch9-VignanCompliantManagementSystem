<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Complaints — Admin CMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="dashboard-body">
<%- include('../partials/admin-sidebar', { activePage: 'complaints' }) %>
<div class="main-content" id="mainContent">
    <div class="topbar">
        <div class="topbar-left">
            <div class="breadcrumb"><span>Admin</span><i class="fas fa-chevron-right"></i><span>Complaints</span></div>
            <h1><i class="fas fa-folder-open"></i> All Complaints</h1>
        </div>
    </div>

    <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success fade-in"><i class="fas fa-check-circle"></i> <%= success %><button class="alert-close" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button></div><% } %>

    <div class="card filter-card">
        <div class="card-body" style="padding:1rem 1.5rem">
            <form method="GET" action="/admin/complaints">
                <div class="filter-row">
                    <div class="filter-group" style="flex:2"><label>Search</label><input type="text" name="search" class="form-control" placeholder="Search by ID, title, student..." value="<%= typeof filters !== 'undefined' ? (filters.search||'') : '' %>" /></div>
                    <div class="filter-group"><label>Status</label>
                        <select name="status" class="form-control"><option value="">All Status</option>
                        <% ['Pending','In Progress','Resolved','Rejected'].forEach(s=>{%><option value="<%= s %>" <%=(typeof filters!=='undefined'&&filters.status===s)?'selected':''%>><%= s %></option><%})%></select>
                    </div>
                    <div class="filter-group"><label>Category</label>
                        <select name="category" class="form-control"><option value="">All Categories</option>
                        <%['Infrastructure','Academic','Hostel','Library','Transport','Canteen','IT / Network','Electrical','Sanitation','Sports','Administrative','Other'].forEach(cat=>{%><option value="<%= cat %>" <%=(typeof filters!=='undefined'&&filters.category===cat)?'selected':''%>><%= cat %></option><%})%></select>
                    </div>
                    <div class="filter-group"><label>Priority</label>
                        <select name="priority" class="form-control"><option value="">All Priorities</option>
                        <%['High','Medium','Low'].forEach(p=>{%><option value="<%= p %>" <%=(typeof filters!=='undefined'&&filters.priority===p)?'selected':''%>><%= p %></option><%})%></select>
                    </div>
                    <div class="filter-actions"><button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filter</button><a href="/admin/complaints" class="btn btn-outline"><i class="fas fa-times"></i></a></div>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h3><i class="fas fa-list"></i> Results (<%= complaints.length %>)</h3></div>
        <div class="card-body" style="padding:0">
            <% if (complaints.length === 0) { %>
            <div class="empty-state"><i class="fas fa-inbox"></i><h4>No complaints found</h4></div>
            <% } else { %>
            <div class="table-responsive">
                <table class="data-table">
                    <thead><tr><th>ID</th><th>Title</th><th>Student</th><th>Category</th><th>Dept</th><th>Priority</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
                    <tbody>
                        <% complaints.forEach(c => { %>
                        <tr>
                            <td><span class="complaint-id"><%= c.complaint_id %></span></td>
                            <td class="complaint-title"><%= c.title %></td>
                            <td><div class="user-cell"><strong><%= c.user_name %></strong><small><%= c.user_email %></small></div></td>
                            <td><span class="category-badge"><%= c.category %></span></td>
                            <td style="font-size:0.8rem;color:var(--text-muted)"><%= c.department %></td>
                            <td><span class="priority-badge priority-<%= c.priority.toLowerCase() %>"><%= c.priority %></span></td>
                            <td><span class="status-badge status-<%= c.status.toLowerCase().replace(' ','-') %>"><%= c.status %></span></td>
                            <td style="color:var(--text-muted);font-size:0.78rem"><%= new Date(c.created_at).toLocaleDateString('en-IN') %></td>
                            <td><a href="/admin/complaints/<%= c.id %>" class="btn btn-xs btn-view"><i class="fas fa-eye"></i> View</a></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </div>
</div>
<script src="/js/admin.js"></script>
</body>
</html>
