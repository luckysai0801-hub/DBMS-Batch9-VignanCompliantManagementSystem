<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vignan VITS — Complaint Management System</title>
    <meta name="description" content="A streamlined complaint management portal for Vignan Institute of Technology and Science students.">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<!-- Flash Messages -->
<% if (success) { %>
<div class="alert alert-success" id="flashMsg">
    <i class="fas fa-check-circle"></i> <%= success %>
    <button class="alert-close" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
</div>
<% } %>
<% if (error) { %>
<div class="alert alert-error" id="flashMsg">
    <i class="fas fa-exclamation-circle"></i> <%= error %>
    <button class="alert-close" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
</div>
<% } %>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-content">
        <div class="hero-badge">
            <i class="fas fa-graduation-cap"></i> Vignan Institute of Technology and Science
        </div>
        <h1 class="hero-title">
            Complaint Management <span class="text-gradient">System</span>
        </h1>
        <p class="hero-subtitle">
            A streamlined platform for students to raise complaints and track their resolution. 
            Fast, transparent, and efficient.
        </p>
        <div class="hero-buttons">
            <a href="/register" class="btn btn-primary btn-lg">
                <i class="fas fa-user-plus"></i> Register Now
            </a>
            <a href="/login" class="btn btn-outline btn-lg">
                <i class="fas fa-sign-in-alt"></i> Student Login
            </a>
        </div>
        <div class="hero-stats">
            <div class="hero-stat">
                <strong>Fast</strong>
                <span>Resolution</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <strong>Live</strong>
                <span>Tracking</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <strong>Secure</strong>
                <span>System</span>
            </div>
        </div>
    </div>
    <div class="hero-image">
        <div class="hero-card">
            <div class="hero-card-header">
                <span class="status-badge status-pending">Pending</span>
                <span class="complaint-id">CMP001</span>
            </div>
            <h4>Classroom Projector Issue</h4>
            <p>Lab Block - IT Department</p>
            <div class="hero-card-footer">
                <span><i class="fas fa-clock"></i> 2 hours ago</span>
                <span class="priority-badge priority-high">High</span>
            </div>
        </div>
        <div class="hero-card hero-card-2">
            <div class="hero-card-header">
                <span class="status-badge status-resolved">Resolved</span>
                <span class="complaint-id">CMP002</span>
            </div>
            <h4>Water Cooler Not Working</h4>
            <p>Block A - Facilities</p>
            <div class="hero-card-footer">
                <span><i class="fas fa-check"></i> Resolved</span>
                <span class="priority-badge priority-medium">Medium</span>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features" id="features">
    <div class="container">
        <div class="section-header">
            <h2>Why Use Our System?</h2>
            <p>Everything you need to manage and track complaints efficiently</p>
        </div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon" style="background: linear-gradient(135deg, #10B981, #059669)">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3>Secure & Private</h3>
                <p>Your complaints are protected with bcrypt password hashing and secure sessions.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background: linear-gradient(135deg, #34D399, #10B981)">
                    <i class="fas fa-search"></i>
                </div>
                <h3>Track in Real-Time</h3>
                <p>Follow your complaint status from Pending to Resolved with full update history.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background: linear-gradient(135deg, #059669, #047857)">
                    <i class="fas fa-users-cog"></i>
                </div>
                <h3>Admin Management</h3>
                <p>Admins can assign complaints, update status, and respond with remarks.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background: linear-gradient(135deg, #6EE7B7, #10B981)">
                    <i class="fas fa-chart-pie"></i>
                </div>
                <h3>Detailed Reports</h3>
                <p>Visual reports by category, department, and priority for campus analysis.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background: linear-gradient(135deg, #047857, #064E3B)">
                    <i class="fas fa-image"></i>
                </div>
                <h3>Image Evidence</h3>
                <p>Attach photos to your complaint for better understanding and faster resolution.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background: linear-gradient(135deg, #A7F3D0, #34D399)">
                    <i class="fas fa-mobile-alt"></i>
                </div>
                <h3>Mobile Friendly</h3>
                <p>Access from any device – phone, tablet, or desktop with responsive design.</p>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="how-it-works">
    <div class="container">
        <div class="section-header">
            <h2>How It Works</h2>
            <p>Simple 4-step process to get your issues resolved</p>
        </div>
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">1</div>
                <h3>Register</h3>
                <p>Create your student account with your college email and secure password.</p>
            </div>
            <div class="step-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="step-card">
                <div class="step-number">2</div>
                <h3>Submit</h3>
                <p>Fill in complaint details – category, department, priority, and description.</p>
            </div>
            <div class="step-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="step-card">
                <div class="step-number">3</div>
                <h3>Track</h3>
                <p>Monitor status updates and admin remarks in real-time on your dashboard.</p>
            </div>
            <div class="step-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="step-card">
                <div class="step-number">4</div>
                <h3>Resolved!</h3>
                <p>Receive confirmation once your complaint is reviewed and resolved by admin.</p>
            </div>
        </div>
    </div>
</section>

<!-- Status Info Section -->
<section class="status-info">
    <div class="container">
        <div class="section-header">
            <h2>Complaint Status Flow</h2>
            <p>Track every stage of your complaint lifecycle</p>
        </div>
        <div class="status-cards">
            <div class="status-info-card" style="border-top: 4px solid #f59e0b">
                <i class="fas fa-clock" style="color: #f59e0b"></i>
                <h4>Pending</h4>
                <p>Your complaint is submitted and waiting for admin review.</p>
            </div>
            <div class="status-info-card" style="border-top: 4px solid #3b82f6">
                <i class="fas fa-spinner" style="color: #3b82f6"></i>
                <h4>In Progress</h4>
                <p>Admin has reviewed and is actively working on your complaint.</p>
            </div>
            <div class="status-info-card" style="border-top: 4px solid #10b981">
                <i class="fas fa-check-circle" style="color: #10b981"></i>
                <h4>Resolved</h4>
                <p>Your complaint has been successfully addressed and closed.</p>
            </div>
            <div class="status-info-card" style="border-top: 4px solid #ef4444">
                <i class="fas fa-times-circle" style="color: #ef4444"></i>
                <h4>Rejected</h4>
                <p>Complaint was reviewed and not actionable. Admin will provide remarks.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="cta-content">
        <h2>Ready to Submit a Complaint?</h2>
        <p>Join the Vignan VITS CMS platform and get your issues resolved faster than ever.</p>
        <div class="cta-buttons">
            <a href="/register" class="btn btn-primary btn-lg">
                <i class="fas fa-user-plus"></i> Get Started Free
            </a>
            <a href="/login" class="btn btn-outline btn-lg">
                <i class="fas fa-sign-in-alt"></i> Already Registered?
            </a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
<script>
document.getElementById('navToggle').onclick = function(){
    document.getElementById('navLinks').classList.toggle('open');
};
</script>
</body>
</html>
